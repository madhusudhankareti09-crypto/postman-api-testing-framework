        {
          "name": "CreateUser",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomPhone() {\r",
                  "    return \"9\" + Math.floor(100000000 + Math.random() * 900000000).toString().slice(1);\r",
                  "}\r",
                  "\r",
                  "function customPassword() {\r",
                  "    return \"Test@\" + Math.floor(1000 + Math.random() * 9000);\r",
                  "}\r",
                  "\r",
                  "pm.environment.set(\"id\", Date.now()); // unique timestamp-based ID\r",
                  "pm.environment.set(\"phone\", randomPhone());\r",
                  "pm.environment.set(\"password\", customPassword());\r",
                  "pm.environment.set(\"firstName\", pm.variables.replaceIn(\"{{$randomFirstName}}\"));\r",
                  "pm.environment.set(\"lastName\", pm.variables.replaceIn(\"{{$randomLastName}}\"));\r",
                  "pm.environment.set(\"username\", pm.variables.replaceIn(\"{{$randomUserName}}\"));\r",
                  "pm.environment.set(\"email\", pm.variables.replaceIn(\"{{$randomEmail}}\"));\r",
                  "pm.environment.set(\"userStatus\", Math.floor(Math.random() * 2)); // 0 or 1"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  ""
                ],
